---
// AnimationScript.astro -- Client-side GSAP animation orchestration
// All animations are progressive enhancement: content is visible without JS.
// This script runs after DOM parse (Vite bundles as deferred module).
---

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";

  gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {

    // ========================================
    // 1. HERO LOAD ANIMATION
    // ========================================
    // Sequence: headline > paragraph > Fano plane (point-line-point-line...)

    const heroTl = gsap.timeline({ delay: 0.2 });

    // Headline fade up
    heroTl.to("[data-hero-headline]", {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out",
    });

    // Paragraph fade up
    heroTl.to("[data-hero-paragraph]", {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: "power2.out",
    }, "-=0.3");

    // Fano plane: sequential point-line-point using data-fano-seq ordering
    // Each element animates in order: point fades in, then line draws, etc.
    const fanoElements = gsap.utils.toArray("[data-fano-seq]");
    if (fanoElements.length) {
      // Hide all lines initially
      const fanoLines = gsap.utils.toArray("[data-fano-line]");
      gsap.set(fanoLines, { drawSVG: "0%" });

      // Animate each element in sequence order
      fanoElements.sort((a: Element, b: Element) => {
        return Number(a.getAttribute("data-fano-seq")) - Number(b.getAttribute("data-fano-seq"));
      });

      let fanoOffset = "+=0.3"; // initial delay after paragraph
      for (const el of fanoElements) {
        const isLine = el.hasAttribute("data-fano-line");
        if (isLine) {
          // Lines draw on
          heroTl.to(el, {
            drawSVG: "100%",
            opacity: 1,
            duration: 0.3,
            ease: "power1.inOut",
          }, fanoOffset);
        } else {
          // Points fade in
          heroTl.to(el, {
            opacity: 1,
            duration: 0.2,
            ease: "power2.out",
          }, fanoOffset);
        }
        fanoOffset = "-=0.05"; // slight overlap between elements
      }
    }

    // ========================================
    // 2. SECTION SCROLL REVEALS
    // ========================================
    gsap.utils.toArray('[data-animate="section-reveal"]').forEach((section) => {
      gsap.to(section, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 70%",
          once: true,
        },
      });

      // Equation stagger within this section
      const equations = (section as Element).querySelectorAll(".katex-display");
      if (equations.length) {
        gsap.to(equations, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          stagger: 0.2,
          scrollTrigger: {
            trigger: section,
            start: "top 70%",
            once: true,
          },
          delay: 0.3,
        });
      }
    });

    // ========================================
    // 3. ARCHITECTURE SECTION + TRIE ANIMATION
    // ========================================
    // Trie grows: root appears > edge draws > child appears > edge draws > grandchild appears...

    const archSection = document.querySelector('[data-animate="architecture"]');
    if (archSection) {
      gsap.to(archSection, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: {
          trigger: archSection,
          start: "top 70%",
          once: true,
        },
      });

      // Equation stagger
      const archEquations = archSection.querySelectorAll(".katex-display");
      if (archEquations.length) {
        gsap.to(archEquations, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          stagger: 0.2,
          scrollTrigger: {
            trigger: archSection,
            start: "top 70%",
            once: true,
          },
          delay: 0.3,
        });
      }

      // Trie: sequential node-edge-node using data-trie-seq ordering
      const trieElements = gsap.utils.toArray("[data-trie-seq]");
      if (trieElements.length) {
        const trieEdges = gsap.utils.toArray("[data-trie-edge]");
        gsap.set(trieEdges, { drawSVG: "0%" });

        trieElements.sort((a: Element, b: Element) => {
          return Number(a.getAttribute("data-trie-seq")) - Number(b.getAttribute("data-trie-seq"));
        });

        const trieTl = gsap.timeline({
          scrollTrigger: {
            trigger: archSection,
            start: "top 70%",
            once: true,
          },
          delay: 0.5, // wait for section reveal
        });

        for (const el of trieElements) {
          const isEdge = el.hasAttribute("data-trie-edge");
          if (isEdge) {
            trieTl.to(el, {
              drawSVG: "100%",
              opacity: 1,
              duration: 0.35,
              ease: "power1.inOut",
            }, "-=0.05");
          } else {
            trieTl.to(el, {
              opacity: 1,
              duration: 0.25,
              ease: "power2.out",
            }, "-=0.05");
          }
        }

        // Labels fade in after tree is drawn
        trieTl.to("[data-trie-label]", {
          opacity: 1,
          duration: 0.4,
          ease: "power2.out",
          stagger: 0.08,
        }, "+=0.1");
      }
    }

    // ========================================
    // 4. RESULTS TABLE ROW STAGGER
    // ========================================
    const resultsSection = document.querySelector('[data-animate="results"]');
    if (resultsSection) {
      gsap.to(resultsSection, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: {
          trigger: resultsSection,
          start: "top 70%",
          once: true,
        },
      });

      const resultRows = resultsSection.querySelectorAll("[data-result-row]");
      if (resultRows.length) {
        gsap.to(resultRows, {
          opacity: 1,
          y: 0,
          duration: 0.4,
          ease: "power2.out",
          stagger: 0.15,
          scrollTrigger: {
            trigger: resultsSection,
            start: "top 70%",
            once: true,
          },
          delay: 0.3,
        });
      }
    }

    // ========================================
    // 5. COMPARISON TABLE ROW STAGGER
    // ========================================
    const compSection = document.querySelector('[data-animate="comparison"]');
    if (compSection) {
      gsap.to(compSection, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: {
          trigger: compSection,
          start: "top 70%",
          once: true,
        },
      });

      const compRows = compSection.querySelectorAll("[data-comparison-row]");
      if (compRows.length) {
        gsap.to(compRows, {
          opacity: 1,
          y: 0,
          duration: 0.4,
          ease: "power2.out",
          stagger: 0.15,
          scrollTrigger: {
            trigger: compSection,
            start: "top 70%",
            once: true,
          },
          delay: 0.3,
        });
      }
    }

  }); // end matchMedia
</script>
