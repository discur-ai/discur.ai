---
// AnimationScript.astro -- Client-side GSAP animation orchestration
// Progressive enhancement: content visible without JS.
---

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";

  gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {

    // ========================================
    // 1. HERO LOAD ANIMATION
    // ========================================

    const heroTl = gsap.timeline({ delay: 0.2 });

    heroTl.to("[data-hero-headline]", {
      opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
    });

    heroTl.to("[data-hero-paragraph]", {
      opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
    }, "-=0.4");

    // Fano plane: smooth sequential point-line-point
    // Each step overlaps the previous by ~60% for a flowing feel
    const fanoElements = gsap.utils.toArray("[data-fano-seq]");
    if (fanoElements.length) {
      const fanoLines = gsap.utils.toArray("[data-fano-line]");
      gsap.set(fanoLines, { drawSVG: "0%", opacity: 0 });

      fanoElements.sort((a: Element, b: Element) =>
        Number(a.getAttribute("data-fano-seq")) - Number(b.getAttribute("data-fano-seq"))
      );

      // Use staggered labels on the timeline for smooth overlapping
      let t = 0;
      const pointDur = 0.4;
      const lineDur = 0.5;
      const stepGap = 0.2; // time between each element start

      for (const el of fanoElements) {
        const isLine = el.hasAttribute("data-fano-line");
        if (isLine) {
          heroTl.to(el, {
            drawSVG: "100%", opacity: 1,
            duration: lineDur, ease: "power2.inOut",
          }, `fano+=${t}`);
        } else {
          heroTl.to(el, {
            opacity: 1,
            duration: pointDur, ease: "power2.out",
          }, `fano+=${t}`);
        }
        t += stepGap;
      }
    }

    // ========================================
    // 2. SECTION SCROLL REVEALS
    // ========================================
    gsap.utils.toArray('[data-animate="section-reveal"]').forEach((section) => {
      gsap.to(section, {
        opacity: 1, y: 0, duration: 0.7, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 75%", once: true },
      });

      const equations = (section as Element).querySelectorAll(".katex-display");
      if (equations.length) {
        gsap.to(equations, {
          opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
          stagger: 0.2, delay: 0.3,
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }
    });

    // ========================================
    // 3. ARCHITECTURE SECTION + TRIE GROWTH
    // ========================================

    const archSection = document.querySelector('[data-animate="architecture"]');
    if (archSection) {
      gsap.to(archSection, {
        opacity: 1, y: 0, duration: 0.7, ease: "power2.out",
        scrollTrigger: { trigger: archSection, start: "top 75%", once: true },
      });

      const archEquations = archSection.querySelectorAll(".katex-display");
      if (archEquations.length) {
        gsap.to(archEquations, {
          opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
          stagger: 0.2, delay: 0.3,
          scrollTrigger: { trigger: archSection, start: "top 75%", once: true },
        });
      }

      // Trie growth: smooth sequential with overlapping steps
      const trieElements = gsap.utils.toArray("[data-trie-seq]");
      if (trieElements.length) {
        const trieEdges = gsap.utils.toArray("[data-trie-edge]");
        gsap.set(trieEdges, { drawSVG: "0%", opacity: 0 });

        trieElements.sort((a: Element, b: Element) =>
          Number(a.getAttribute("data-trie-seq")) - Number(b.getAttribute("data-trie-seq"))
        );

        const trieTl = gsap.timeline({
          scrollTrigger: { trigger: archSection, start: "top 75%", once: true },
          delay: 0.6,
        });

        let t = 0;
        const nodeDur = 0.4;
        const edgeDur = 0.5;
        const gap = 0.2;

        for (const el of trieElements) {
          const isEdge = el.hasAttribute("data-trie-edge");
          if (isEdge) {
            trieTl.to(el, {
              drawSVG: "100%", opacity: 1,
              duration: edgeDur, ease: "power2.inOut",
            }, `trie+=${t}`);
          } else {
            trieTl.to(el, {
              opacity: 1,
              duration: nodeDur, ease: "power2.out",
            }, `trie+=${t}`);
          }
          t += gap;
        }

        // Labels fade in smoothly after tree finishes
        trieTl.to("[data-trie-label]", {
          opacity: 1, duration: 0.6, ease: "power2.out", stagger: 0.1,
        }, `trie+=${t + 0.2}`);
      }
    }

    // ========================================
    // 4. RESULTS TABLE ROW STAGGER
    // ========================================
    const resultsSection = document.querySelector('[data-animate="results"]');
    if (resultsSection) {
      gsap.to(resultsSection, {
        opacity: 1, y: 0, duration: 0.7, ease: "power2.out",
        scrollTrigger: { trigger: resultsSection, start: "top 75%", once: true },
      });
      const resultRows = resultsSection.querySelectorAll("[data-result-row]");
      if (resultRows.length) {
        gsap.to(resultRows, {
          opacity: 1, y: 0, duration: 0.5, ease: "power2.out",
          stagger: 0.15, delay: 0.3,
          scrollTrigger: { trigger: resultsSection, start: "top 75%", once: true },
        });
      }
    }

    // ========================================
    // 5. COMPARISON TABLE ROW STAGGER
    // ========================================
    const compSection = document.querySelector('[data-animate="comparison"]');
    if (compSection) {
      gsap.to(compSection, {
        opacity: 1, y: 0, duration: 0.7, ease: "power2.out",
        scrollTrigger: { trigger: compSection, start: "top 75%", once: true },
      });
      const compRows = compSection.querySelectorAll("[data-comparison-row]");
      if (compRows.length) {
        gsap.to(compRows, {
          opacity: 1, y: 0, duration: 0.5, ease: "power2.out",
          stagger: 0.15, delay: 0.3,
          scrollTrigger: { trigger: compSection, start: "top 75%", once: true },
        });
      }
    }

    // ========================================
    // 6. CONSTELLATION BACKGROUND ANIMATION
    // ========================================
    const constellationPoints = document.querySelectorAll("[data-constellation-point]");
    if (constellationPoints.length) {
      constellationPoints.forEach((point) => {
        const cx = Number(point.getAttribute("cx"));
        const cy = Number(point.getAttribute("cy"));
        // Each point drifts in a small random orbit
        gsap.to(point, {
          attr: {
            cx: cx + (Math.random() - 0.5) * 40,
            cy: cy + (Math.random() - 0.5) * 30,
          },
          duration: 8 + Math.random() * 6,
          ease: "sine.inOut",
          repeat: -1,
          yoyo: true,
        });
      });
    }

    const constellationLines = document.querySelectorAll("[data-constellation-line]");
    if (constellationLines.length) {
      constellationLines.forEach((line) => {
        // Lines follow their connected points (update happens via GSAP ticker)
        gsap.to(line, {
          opacity: 0.04,
          duration: 4 + Math.random() * 4,
          ease: "sine.inOut",
          repeat: -1,
          yoyo: true,
        });
      });
    }

  }); // end matchMedia
</script>
