---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// Fano plane geometry: equilateral triangle with vertices, edge midpoints, centroid.
const cx = 200, cy = 190;
const R = 150;
const P1 = { x: cx, y: cy - R };
const P2 = { x: cx - R * Math.cos(Math.PI/6), y: cy + R * Math.sin(Math.PI/6) };
const P3 = { x: cx + R * Math.cos(Math.PI/6), y: cy + R * Math.sin(Math.PI/6) };
const P4 = { x: (P1.x + P2.x) / 2, y: (P1.y + P2.y) / 2 };
const P5 = { x: (P1.x + P3.x) / 2, y: (P1.y + P3.y) / 2 };
const P6 = { x: (P2.x + P3.x) / 2, y: (P2.y + P3.y) / 2 };
const P7 = { x: (P1.x + P2.x + P3.x) / 3, y: (P1.y + P2.y + P3.y) / 3 };
const inscribedR = Math.sqrt((P7.x - P4.x) ** 2 + (P7.y - P4.y) ** 2);
const r = (v: number) => Math.round(v * 10) / 10;

// Ordered sequence: point appears, then line draws from it.
// P1 > line P1-P2 > P2 > line P2-P3 > P3 > line P3-P1 (triangle done)
// > line P1-P6 (median) > P4 (midpoint on left edge) > line P2-P5 (median) > P5 > line P3-P4 (median)
// > P6 (bottom midpoint) > inscribed circle > P7 (centroid)
// Each node/line has data-fano-seq="N" for animation ordering.
---

<svg
  viewBox="0 0 400 380"
  xmlns="http://www.w3.org/2000/svg"
  class:list={[className]}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label="Fano plane diagram showing the seven quaternionic subalgebras of the octonions"
>
  <defs>
    <filter id="fano-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Sequence: nodes and lines interleaved for point-then-line animation -->

  <!-- 1. P1 (top vertex) -->
  <circle cx={r(P1.x)} cy={r(P1.y)} r="7" fill="#8B6914" filter="url(#fano-glow)" data-fano-node data-fano-seq="1"/>
  <!-- 2. Line P1 to P2 -->
  <line x1={r(P1.x)} y1={r(P1.y)} x2={r(P2.x)} y2={r(P2.y)} stroke="#8B6914" stroke-width="1.5" data-fano-line data-fano-seq="2" pathLength="1"/>
  <!-- 3. P2 (bottom-left) -->
  <circle cx={r(P2.x)} cy={r(P2.y)} r="7" fill="#A68930" filter="url(#fano-glow)" data-fano-node data-fano-seq="3"/>
  <!-- 4. Line P2 to P3 -->
  <line x1={r(P2.x)} y1={r(P2.y)} x2={r(P3.x)} y2={r(P3.y)} stroke="#A68930" stroke-width="1.5" data-fano-line data-fano-seq="4" pathLength="1"/>
  <!-- 5. P3 (bottom-right) -->
  <circle cx={r(P3.x)} cy={r(P3.y)} r="7" fill="#7A5C12" filter="url(#fano-glow)" data-fano-node data-fano-seq="5"/>
  <!-- 6. Line P3 to P1 (closes triangle) -->
  <line x1={r(P3.x)} y1={r(P3.y)} x2={r(P1.x)} y2={r(P1.y)} stroke="#7A5C12" stroke-width="1.5" data-fano-line data-fano-seq="6" pathLength="1"/>
  <!-- 7. Line P1 to P6 (first median) -->
  <line x1={r(P1.x)} y1={r(P1.y)} x2={r(P6.x)} y2={r(P6.y)} stroke="#6B4C0E" stroke-width="1.5" data-fano-line data-fano-seq="7" pathLength="1"/>
  <!-- 8. P6 (bottom midpoint, appears as median reaches it) -->
  <circle cx={r(P6.x)} cy={r(P6.y)} r="7" fill="#6B4C0E" filter="url(#fano-glow)" data-fano-node data-fano-seq="8"/>
  <!-- 9. Line P2 to P5 (second median) -->
  <line x1={r(P2.x)} y1={r(P2.y)} x2={r(P5.x)} y2={r(P5.y)} stroke="#9B7A20" stroke-width="1.5" data-fano-line data-fano-seq="9" pathLength="1"/>
  <!-- 10. P5 (right midpoint) -->
  <circle cx={r(P5.x)} cy={r(P5.y)} r="7" fill="#9B7A20" filter="url(#fano-glow)" data-fano-node data-fano-seq="10"/>
  <!-- 11. Line P3 to P4 (third median) -->
  <line x1={r(P3.x)} y1={r(P3.y)} x2={r(P4.x)} y2={r(P4.y)} stroke="#B8960A" stroke-width="1.5" data-fano-line data-fano-seq="11" pathLength="1"/>
  <!-- 12. P4 (left midpoint) -->
  <circle cx={r(P4.x)} cy={r(P4.y)} r="7" fill="#B8960A" filter="url(#fano-glow)" data-fano-node data-fano-seq="12"/>
  <!-- 13. Inscribed circle -->
  <circle cx={r(P7.x)} cy={r(P7.y)} r={r(inscribedR)} stroke="#8B6914" stroke-width="1.5" fill="none" data-fano-line data-fano-seq="13" pathLength="1"/>
  <!-- 14. P7 (centroid, last to appear) -->
  <circle cx={r(P7.x)} cy={r(P7.y)} r="7" fill="#8B6914" filter="url(#fano-glow)" data-fano-node data-fano-seq="14"/>
</svg>
