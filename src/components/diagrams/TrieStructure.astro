---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 500 320"
  xmlns="http://www.w3.org/2000/svg"
  class:list={[className]}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label="Octonionic trie structure showing three levels of hierarchical memory nodes"
>
  <defs>
    <filter id="trie-glow" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Edges -->
  <line x1="250" y1="50" x2="100" y2="150" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>
  <line x1="250" y1="50" x2="250" y2="150" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>
  <line x1="250" y1="50" x2="400" y2="150" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>
  <line x1="100" y1="150" x2="50" y2="260" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>
  <line x1="100" y1="150" x2="150" y2="260" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>
  <line x1="400" y1="150" x2="400" y2="260" stroke="#C4A35A" stroke-width="1.5" opacity="0.6" data-trie-edge/>

  <!-- Edge labels -->
  <text x="165" y="90" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2081;</text>
  <text x="260" y="90" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2083;</text>
  <text x="335" y="90" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2086;</text>
  <text x="65" y="210" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2082;</text>
  <text x="138" y="210" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2084;</text>
  <text x="412" y="210" fill="#C4A35A" font-family="serif" font-size="13" text-anchor="middle" opacity="0.7" data-trie-label>S&#x2087;</text>

  <!-- Level 0: root -->
  <circle cx="250" cy="50" r="12" fill="#E8D5A3" filter="url(#trie-glow)" data-trie-node="level-0"/>
  <!-- Level 1: children -->
  <circle cx="100" cy="150" r="10" fill="#D4AF37" filter="url(#trie-glow)" data-trie-node="level-1"/>
  <circle cx="250" cy="150" r="10" fill="#D4AF37" filter="url(#trie-glow)" data-trie-node="level-1"/>
  <circle cx="400" cy="150" r="10" fill="#D4AF37" filter="url(#trie-glow)" data-trie-node="level-1"/>
  <!-- Level 2: grandchildren -->
  <circle cx="50" cy="260" r="8" fill="#C4A35A" filter="url(#trie-glow)" data-trie-node="level-2"/>
  <circle cx="150" cy="260" r="8" fill="#C4A35A" filter="url(#trie-glow)" data-trie-node="level-2"/>
  <circle cx="400" cy="260" r="8" fill="#C4A35A" filter="url(#trie-glow)" data-trie-node="level-2"/>
</svg>
