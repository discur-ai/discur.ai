---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 500 320"
  xmlns="http://www.w3.org/2000/svg"
  class:list={[className]}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label="Octonionic trie structure showing three levels of hierarchical memory nodes"
>
  <defs>
    <filter id="trie-glow" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Edges: draw sequentially as tree "grows" -->
  <!-- Level 0 to Level 1 edges -->
  <line x1="250" y1="50" x2="100" y2="150" stroke="#8B6914" stroke-width="1.5" data-trie-edge data-trie-seq="2" pathLength="1"/>
  <line x1="250" y1="50" x2="250" y2="150" stroke="#8B6914" stroke-width="1.5" data-trie-edge data-trie-seq="4" pathLength="1"/>
  <line x1="250" y1="50" x2="400" y2="150" stroke="#8B6914" stroke-width="1.5" data-trie-edge data-trie-seq="6" pathLength="1"/>
  <!-- Level 1 to Level 2 edges -->
  <line x1="100" y1="150" x2="50" y2="260" stroke="#A68930" stroke-width="1.5" data-trie-edge data-trie-seq="8" pathLength="1"/>
  <line x1="100" y1="150" x2="150" y2="260" stroke="#A68930" stroke-width="1.5" data-trie-edge data-trie-seq="10" pathLength="1"/>
  <line x1="400" y1="150" x2="400" y2="260" stroke="#A68930" stroke-width="1.5" data-trie-edge data-trie-seq="12" pathLength="1"/>

  <!-- Edge labels -->
  <text x="165" y="90" fill="#8B6914" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2081;</text>
  <text x="260" y="90" fill="#8B6914" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2083;</text>
  <text x="335" y="90" fill="#8B6914" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2086;</text>
  <text x="65" y="210" fill="#A68930" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2082;</text>
  <text x="138" y="210" fill="#A68930" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2084;</text>
  <text x="412" y="210" fill="#A68930" font-family="serif" font-size="13" text-anchor="middle" data-trie-label>S&#x2087;</text>

  <!-- Nodes: appear at each level as tree grows -->
  <!-- seq 1: root appears first -->
  <circle cx="250" cy="50" r="12" fill="#8B6914" filter="url(#trie-glow)" data-trie-node="level-0" data-trie-seq="1"/>
  <!-- seq 3,5,7: children appear after their edge draws -->
  <circle cx="100" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="3"/>
  <circle cx="250" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="5"/>
  <circle cx="400" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="7"/>
  <!-- seq 9,11,13: grandchildren appear after their edge draws -->
  <circle cx="50" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="9"/>
  <circle cx="150" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="11"/>
  <circle cx="400" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="13"/>
</svg>
