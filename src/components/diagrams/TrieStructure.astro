---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// Edge definitions with label offset perpendicular to edge direction
const edges = [
  { x1: 250, y1: 50, x2: 100, y2: 150, label: "S\u2081", seq: 2 },
  { x1: 250, y1: 50, x2: 250, y2: 150, label: "S\u2083", seq: 4 },
  { x1: 250, y1: 50, x2: 400, y2: 150, label: "S\u2086", seq: 6 },
  { x1: 100, y1: 150, x2: 50, y2: 260, label: "S\u2082", seq: 8 },
  { x1: 100, y1: 150, x2: 150, y2: 260, label: "S\u2084", seq: 10 },
  { x1: 400, y1: 150, x2: 400, y2: 260, label: "S\u2087", seq: 12 },
].map(e => {
  // Midpoint of edge
  const mx = (e.x1 + e.x2) / 2;
  const my = (e.y1 + e.y2) / 2;
  // Edge direction vector
  const dx = e.x2 - e.x1;
  const dy = e.y2 - e.y1;
  const len = Math.sqrt(dx * dx + dy * dy);
  // Perpendicular unit vector (rotated 90° CCW)
  const px = -dy / len;
  const py = dx / len;
  // Offset label 18px perpendicular to the edge (to the right side looking from start to end)
  const offset = 18;
  return {
    ...e,
    lx: Math.round(mx + px * offset),
    ly: Math.round(my + py * offset),
  };
});
---

<svg
  viewBox="0 0 500 320"
  xmlns="http://www.w3.org/2000/svg"
  class:list={[className]}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label="Octonionic trie structure showing three levels of hierarchical memory nodes"
>
  <defs>
    <filter id="trie-glow" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  {edges.map(e => (
    <>
      <line x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2}
        stroke="#8B6914" stroke-width="1.5"
        data-trie-edge data-trie-seq={e.seq} pathLength="1"/>
      <text x={e.lx} y={e.ly} fill="#8B6914" font-family="serif" font-size="12"
        text-anchor="middle" dominant-baseline="middle"
        data-trie-label data-trie-seq={e.seq}>{e.label}</text>
    </>
  ))}

  {/* Level 0: root */}
  <circle cx="250" cy="50" r="12" fill="#8B6914" filter="url(#trie-glow)" data-trie-node="level-0" data-trie-seq="1"/>
  {/* Level 1 */}
  <circle cx="100" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="3"/>
  <circle cx="250" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="5"/>
  <circle cx="400" cy="150" r="10" fill="#A68930" filter="url(#trie-glow)" data-trie-node="level-1" data-trie-seq="7"/>
  {/* Level 2 */}
  <circle cx="50" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="9"/>
  <circle cx="150" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="11"/>
  <circle cx="400" cy="260" r="8" fill="#7A5C12" filter="url(#trie-glow)" data-trie-node="level-2" data-trie-seq="13"/>
</svg>
