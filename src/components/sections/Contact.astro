---
import Section from '../ui/Section.astro';
---

<Section id="contact" dataAnimate="section-reveal">
  <h2 class="font-display text-2xl sm:text-3xl text-sigil mb-12 tracking-wider uppercase">
    Paper
  </h2>

  <p class="text-chalk leading-relaxed mb-6">
    The full technical treatment, including proofs, experimental methodology, and open questions, is available on GitHub.
  </p>

  <a href="https://github.com/discur-ai" class="inline-flex items-center text-sigil hover:text-glyph transition-colors font-display tracking-wider">
    Read the paper
    <svg class="ml-2 w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 3l5 5-5 5" />
    </svg>
  </a>

  <p class="mt-8 text-sm text-chalk-muted">
    <a href="mailto:research@discur.ai" class="hover:text-sigil transition-colors">research@discur.ai</a>
    <span class="mx-3">&middot;</span>
    <a href="https://github.com/discur-ai" class="hover:text-sigil transition-colors">github.com/discur-ai</a>
  </p>
</Section>
