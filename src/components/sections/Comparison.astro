---
import Section from '../ui/Section.astro';
import { COMPARISON_ROWS, ARCHITECTURE_NAMES } from '../../data/comparisons';
---

<Section id="comparison" dataAnimate="comparison">
  <h2 class="font-display text-2xl sm:text-3xl text-sigil mb-12 tracking-wider uppercase">
    Comparison
  </h2>

  <p class="text-chalk leading-relaxed mb-8">
    The octonionic trie shares individual features with existing memory-augmented architectures but combines them through a single algebraic substrate rather than independent engineered components.
  </p>

  <div class="overflow-x-auto overflow-y-hidden rounded-lg border border-sigil-dim/30">
    <table class="w-full text-left text-sm">
      <thead>
        <tr class="border-b border-sigil-dim/30 bg-obsidian">
          <th class="px-4 py-3 font-display text-sm text-chalk-muted tracking-wider uppercase"></th>
          {ARCHITECTURE_NAMES.map((name, i) => (
            <th
              class:list={[
                'px-4 py-3 font-display text-sm tracking-wider',
                i === ARCHITECTURE_NAMES.length - 1
                  ? 'text-sigil border-l border-sigil-dim/30 bg-sigil/5'
                  : 'text-chalk-muted',
              ]}
            >
              {name}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-sigil-dim/20">
        {COMPARISON_ROWS.map((row) => (
          <tr data-comparison-row>
            <td class="px-4 py-3 text-sm text-chalk-muted font-display">{row.property}</td>
            <td class="px-4 py-3 text-sm text-chalk">{row.ntmDnc}</td>
            <td class="px-4 py-3 text-sm text-chalk">{row.sdm}</td>
            <td class="px-4 py-3 text-sm text-chalk">{row.htm}</td>
            <td class="px-4 py-3 text-sm text-sigil border-l border-sigil-dim/30 bg-sigil/5">{row.octTrie}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Section>
