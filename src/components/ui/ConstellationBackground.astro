// Constellation background: fixed position, continuously animated via GSAP
// Points drift slowly, lines connect nearby points and pulse subtly

const points = [
  {x: 72, y: 45}, {x: 215, y: 98}, {x: 380, y: 32}, {x: 510, y: 85},
  {x: 680, y: 48}, {x: 820, y: 112}, {x: 950, y: 35}, {x: 1100, y: 78},
  {x: 1250, y: 52}, {x: 1380, y: 95},
  {x: 45, y: 165}, {x: 180, y: 198}, {x: 305, y: 142}, {x: 460, y: 185},
  {x: 590, y: 158}, {x: 740, y: 195}, {x: 870, y: 148}, {x: 1020, y: 190},
  {x: 1170, y: 155}, {x: 1340, y: 172},
  {x: 120, y: 275}, {x: 250, y: 240}, {x: 370, y: 298}, {x: 520, y: 255},
  {x: 650, y: 280}, {x: 790, y: 248}, {x: 930, y: 292}, {x: 1070, y: 260},
  {x: 1210, y: 275}, {x: 1360, y: 250},
  {x: 60, y: 380}, {x: 195, y: 350}, {x: 340, y: 395}, {x: 475, y: 360},
  {x: 620, y: 385}, {x: 760, y: 355}, {x: 910, y: 390}, {x: 1050, y: 365},
  {x: 1190, y: 380}, {x: 1330, y: 358},
  {x: 95, y: 490}, {x: 230, y: 460}, {x: 385, y: 505}, {x: 530, y: 470},
  {x: 670, y: 498}, {x: 810, y: 465}, {x: 955, y: 490}, {x: 1095, y: 478},
  {x: 1235, y: 460}, {x: 1375, y: 495},
  {x: 55, y: 595}, {x: 200, y: 565}, {x: 355, y: 600}, {x: 490, y: 575},
  {x: 640, y: 595}, {x: 780, y: 558}, {x: 920, y: 590}, {x: 1060, y: 565},
  {x: 1200, y: 580}, {x: 1350, y: 555},
];

// Connect points within range for a web/graph effect
const maxDist = 250;
const lines: {x1: number, y1: number, x2: number, y2: number, i: number, j: number}[] = [];
for (let i = 0; i < points.length; i++) {
  for (let j = i + 1; j < points.length; j++) {
    const dx = points[i].x - points[j].x;
    const dy = points[i].y - points[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < maxDist && dist > 80) {
      lines.push({
        x1: points[i].x, y1: points[i].y,
        x2: points[j].x, y2: points[j].y,
        i, j,
      });
    }
  }
}
---

<div class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index: 0" aria-hidden="true">
  <svg
    id="constellation-svg"
    viewBox="0 0 1440 700"
    preserveAspectRatio="xMidYMid slice"
    width="100%"
    height="100%"
    xmlns="http://www.w3.org/2000/svg"
  >
    {lines.map((l, idx) => (
      <line
        x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2}
        stroke="#D4CDB8" opacity="0.08" stroke-width="0.5"
        data-constellation-line
        data-line-from={l.i} data-line-to={l.j}
      />
    ))}
    {points.map((p, idx) => (
      <circle
        cx={p.x} cy={p.y} r="1.5"
        fill="#D4CDB8" opacity="0.12"
        data-constellation-point
        data-point-idx={idx}
        data-origin-x={p.x} data-origin-y={p.y}
      />
    ))}
  </svg>
</div>

<script>
  // Animate constellation points and update connected lines
  // Runs independently of GSAP matchMedia (decorative, always active)
  function animateConstellation() {
    const points = document.querySelectorAll("[data-constellation-point]");
    const lines = document.querySelectorAll("[data-constellation-line]");
    if (!points.length) return;

    // Store current positions
    const positions = new Map<number, {x: number, y: number}>();
    points.forEach(p => {
      const idx = Number(p.getAttribute("data-point-idx"));
      positions.set(idx, {
        x: Number(p.getAttribute("data-origin-x")),
        y: Number(p.getAttribute("data-origin-y")),
      });
    });

    // Drift each point
    const speed = 0.0003;
    const radius = 20;
    const offsets = Array.from(points).map(() => ({
      angle: Math.random() * Math.PI * 2,
      speed: speed + Math.random() * speed,
      rx: radius + Math.random() * 15,
      ry: radius + Math.random() * 10,
    }));

    function tick(time: number) {
      points.forEach((p, i) => {
        const o = offsets[i];
        const idx = Number(p.getAttribute("data-point-idx"));
        const origin = positions.get(idx)!;
        const nx = origin.x + Math.sin(time * o.speed + o.angle) * o.rx;
        const ny = origin.y + Math.cos(time * o.speed * 0.7 + o.angle) * o.ry;
        p.setAttribute("cx", String(nx));
        p.setAttribute("cy", String(ny));
      });

      // Update lines to follow their connected points
      lines.forEach(line => {
        const fromIdx = Number(line.getAttribute("data-line-from"));
        const toIdx = Number(line.getAttribute("data-line-to"));
        const fromPt = document.querySelector(`[data-point-idx="${fromIdx}"]`);
        const toPt = document.querySelector(`[data-point-idx="${toIdx}"]`);
        if (fromPt && toPt) {
          line.setAttribute("x1", fromPt.getAttribute("cx")!);
          line.setAttribute("y1", fromPt.getAttribute("cy")!);
          line.setAttribute("x2", toPt.getAttribute("cx")!);
          line.setAttribute("y2", toPt.getAttribute("cy")!);
        }
      });

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  // Start after page load
  if (document.readyState === "complete") {
    animateConstellation();
  } else {
    window.addEventListener("load", animateConstellation);
  }
</script>
