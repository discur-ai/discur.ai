---
// Constellation background: scrolls with page, entire SVG drifts gently via CSS
// No per-element JS animation — keeps scroll performance clean

const points = [
  {x: 72, y: 45}, {x: 215, y: 98}, {x: 380, y: 32}, {x: 510, y: 85},
  {x: 680, y: 48}, {x: 820, y: 112}, {x: 950, y: 35}, {x: 1100, y: 78},
  {x: 1250, y: 52}, {x: 1380, y: 95},
  {x: 45, y: 165}, {x: 180, y: 198}, {x: 305, y: 142}, {x: 460, y: 185},
  {x: 590, y: 158}, {x: 740, y: 195}, {x: 870, y: 148}, {x: 1020, y: 190},
  {x: 1170, y: 155}, {x: 1340, y: 172},
  {x: 120, y: 275}, {x: 250, y: 240}, {x: 370, y: 298}, {x: 520, y: 255},
  {x: 650, y: 280}, {x: 790, y: 248}, {x: 930, y: 292}, {x: 1070, y: 260},
  {x: 1210, y: 275}, {x: 1360, y: 250},
  {x: 60, y: 380}, {x: 195, y: 350}, {x: 340, y: 395}, {x: 475, y: 360},
  {x: 620, y: 385}, {x: 760, y: 355}, {x: 910, y: 390}, {x: 1050, y: 365},
  {x: 1190, y: 380}, {x: 1330, y: 358},
  {x: 95, y: 490}, {x: 230, y: 460}, {x: 385, y: 505}, {x: 530, y: 470},
  {x: 670, y: 498}, {x: 810, y: 465}, {x: 955, y: 490}, {x: 1095, y: 478},
  {x: 1235, y: 460}, {x: 1375, y: 495},
  {x: 55, y: 595}, {x: 200, y: 565}, {x: 355, y: 600}, {x: 490, y: 575},
  {x: 640, y: 595}, {x: 780, y: 558}, {x: 920, y: 590}, {x: 1060, y: 565},
  {x: 1200, y: 580}, {x: 1350, y: 555},
];

const maxDist = 250;
const lines: {x1: number, y1: number, x2: number, y2: number}[] = [];
for (let i = 0; i < points.length; i++) {
  for (let j = i + 1; j < points.length; j++) {
    const dx = points[i].x - points[j].x;
    const dy = points[i].y - points[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < maxDist && dist > 80) {
      lines.push({ x1: points[i].x, y1: points[i].y, x2: points[j].x, y2: points[j].y });
    }
  }
}
---

<div class="absolute top-0 left-0 w-full pointer-events-none overflow-hidden" style="z-index: 0; height: 100%;" aria-hidden="true">
  <svg
    class="constellation-drift"
    viewBox="0 0 1920 1080"
    preserveAspectRatio="xMidYMid slice"
    width="100%"
    height="100%"
    xmlns="http://www.w3.org/2000/svg"
    shape-rendering="crispEdges"
  >
    {lines.map(l => (
      <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2}
        stroke="#D4CDB8" opacity="0.20" stroke-width="0.2" />
    ))}
    {points.map(p => (
      <circle cx={p.x} cy={p.y} r="0.25" fill="#C4B99A" opacity="0.20" />
    ))}
  </svg>
</div>

<style>
  /* Entire SVG drifts gently as one unit — lines and dots stay connected */
  .constellation-drift {
    animation: constellation-float 30s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes constellation-float {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(8px, -5px) scale(1.005); }
    66%  { transform: translate(-5px, 8px) scale(0.998); }
    100% { transform: translate(3px, -3px) scale(1.002); }
  }
</style>
